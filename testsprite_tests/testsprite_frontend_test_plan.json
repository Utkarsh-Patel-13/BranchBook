  {
    "id": "T015",
    "title": "Toggle edit mode in notes panel shows Editing status",
    "description": "Verifies that toggling the edit switch in the notes panel header changes the status from 'Read Only' to 'Editing' and shows the editor placeholder.",
    "category": "Notes",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign In\" button"
      },
      {
        "type": "action",
        "description": "Click on the \"HasNodes\" workspace card"
      },
      {
        "type": "action",
        "description": "Click the tab button with aria-label \"Show notes only\" to switch to Notes view"
      },
      {
        "type": "action",
        "description": "Click on \"RootNode\" in the sidebar to select the node"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Read Only\" is visible in the notes panel header"
      },
      {
        "type": "action",
        "description": "Click the \"Edit\" label or the toggle switch (id=\"edit-mode-toggle\") to enable edit mode"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Editing\" is visible in the notes panel header (replacing \"Read Only\")"
      },
      {
        "type": "assertion",
        "description": "Verify the notes editor content area is visible and the \"No note yet\" empty state is gone"
      }
    ]
  },
