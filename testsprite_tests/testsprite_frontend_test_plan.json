  {
    "id": "T014",
    "title": "Selecting a node in notes view shows Read Only header",
    "description": "Verifies that after switching to Notes view and clicking a node in the sidebar, the notes panel header appears showing 'Read Only' status.",
    "category": "Notes",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign In\" button"
      },
      {
        "type": "action",
