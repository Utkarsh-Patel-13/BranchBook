  {
    "id": "T012",
    "title": "Send a chat message and receive a response",
    "description": "Verifies that typing a message and submitting it in the chat sends it and the assistant replies.",
    "category": "Chat",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_USER}}\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"{{LOGIN_PASSWORD}}\" into the password field"
      },
      {
        "type": "action",
        "description": "Click the \"Sign In\" button"
      },
      {
        "type": "action",
        "description": "Click on the \"HasNodes\" workspace card"
      },
      {
        "type": "action",
        "description": "Click on \"RootNode\" in the sidebar"
      },
      {
        "type": "assertion",
        "description": "Verify the chat input with placeholder \"Ask me anything ...\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Hello, say hi back\" into the chat input"
      },
      {
        "type": "action",
        "description": "Press Enter or click the submit button to send the message"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Hello, say hi back\" is visible as a user message"
      },
      {
        "type": "assertion",
        "description": "Verify an assistant response message appears (wait up to 30 seconds for streaming to complete)"
      }
    ]
  },
  {
    "id": "T013",
    "title": "Notes panel shows empty state when no node selected",
    "description": "Verifies that switching to the Notes view without a node selected shows 'No node selected' and the helper text.",
    "category": "Notes",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /login"
      },
      {
        "type": "action",
