generator client {
  provider = "prisma-client"
  output   = "../generated"
  moduleFormat = "esm"
  runtime = "bun"
}

datasource db {
  provider = "postgresql"
}

model Workspace {
  id          String   @id @default(cuid())
  ownerId     String
  owner       User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
  nodes       Node[]

  @@index([ownerId])
  @@index([ownerId, deletedAt])
  @@map("workspace")
}

model Node {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  parentId    String?
  parent      Node?     @relation("NodeChildren", fields: [parentId], references: [id], onDelete: NoAction)
  children    Node[]    @relation("NodeChildren")
  title       String    @db.VarChar(100)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  messages    Message[]
  note        Note?

  // Context Engine
  detailedSummary      String?  @db.Text
  highLevelSummary     String?  @db.Text
  summaryDraft         String?  @db.Text
  summaryDraftCount    Int      @default(0)
  inheritedContext     String?  @db.Text
  branchPointMessageId String?

  @@index([workspaceId])
  @@index([workspaceId, deletedAt])
  @@index([parentId])
  @@index([deletedAt])
  @@map("node")
}

model Note {
  id        String    @id @default(cuid())
  nodeId    String    @unique
  node      Node      @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  content   String    @db.Text
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([nodeId])
  @@index([deletedAt])
  @@map("note")
}

enum MessageRole {
  USER
  ASSISTANT
}

model Message {
  id        String      @id @default(cuid())
  nodeId    String
  node      Node        @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String      @db.Text
  reasoning String?     @db.Text
  sources   Json?
  createdAt DateTime    @default(now())

  // Context Engine
  perMessageSummary String?  @db.Text
  branchPoint       Boolean  @default(false)

  @@index([nodeId, createdAt])
  @@map("message")
}

