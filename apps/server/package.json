    "@fastify/cors": "^11.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "catalog:",
    "ai": "^6.0.78",
    "better-auth": "catalog:",
    "bullmq": "^5.0.0",
