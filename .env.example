# ── Database ─────────────────────────────────────────────────────────────────
# Used by the server container; @postgres is the docker-compose service name
DATABASE_URL=postgresql://postgres:password@postgres:5432/branchbook
# Override the password for the postgres service
POSTGRES_PASSWORD=password

# ── Authentication ────────────────────────────────────────────────────────────
# Must be at least 32 characters
BETTER_AUTH_SECRET=change-me-to-a-random-string-of-32-plus-chars
# Publicly accessible URL of the backend (used by the browser for auth redirects)
BETTER_AUTH_URL=http://localhost:3000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Origin the frontend is served from (what the browser sends as Origin header)
CORS_ORIGIN=http://localhost

# ── AI ────────────────────────────────────────────────────────────────────────
GOOGLE_GENERATIVE_AI_API_KEY=your-google-generative-ai-key-here

# ── Redis ─────────────────────────────────────────────────────────────────────
# @redis is the docker-compose service name; change to your host if external
REDIS_HOST=redis
REDIS_PORT=6379

# ── Frontend ──────────────────────────────────────────────────────────────────
# Publicly accessible URL of the backend — used by the browser to call the API
VITE_SERVER_URL=http://localhost:3000
