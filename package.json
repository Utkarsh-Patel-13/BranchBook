{
  "name": "branchbook",
  "version": "0.0.1",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "@trpc/server": "^11.7.2",
      "better-auth": "^1.4.18",
      "@prisma/client": "^7.2.0",
      "@trpc/tanstack-react-query": "^11.7.2",
      "@trpc/client": "^11.7.2",
      "@tanstack/react-query": "^5.90.12",
      "@better-auth/expo": "^1.4.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:ws": "turbo -F web -F server dev",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:docs": "turbo -F @branchbook/docs start",
    "db:push": "turbo -F @branchbook/db db:push",
    "db:studio": "turbo -F @branchbook/db db:studio",
    "db:generate": "turbo -F @branchbook/db db:generate",
    "db:migrate": "turbo -F @branchbook/db db:migrate",
    "db:start": "turbo -F @branchbook/db db:start",
    "db:watch": "turbo -F @branchbook/db db:watch",
    "db:stop": "turbo -F @branchbook/db db:stop",
    "db:down": "turbo -F @branchbook/db db:down",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@branchbook/env": "workspace:*",
    "@branchbook/config": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.0",
    "@types/bun": "^1.3.9",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.8.10",
    "typescript": "^5.9.3",
    "ultracite": "7.2.2"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.5"
}
